# Polygon market data.
# Get this key from your own Polygon account and add it in Vercel Project Settings > Environment Variables.
# A real-time Polygon plan is required for truly live stock data during market hours.
POLYGON_API_KEY=

# During market hours, minute bars older than this many minutes are rejected.
LIVE_DATA_MAX_AGE_MINUTES=15

# Optional: set true to reject stale minute bars even when the U.S. stock market is closed.
LIVE_DATA_STRICT=false

# Optional future providers. Do not expose provider keys with NEXT_PUBLIC_ prefixes.
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
COINGECKO_API_KEY=
YAHOO_FINANCE_API_KEY=
