# Live market data only.
# Get this key from your own Polygon account and add it in Vercel Project Settings > Environment Variables.
# A real-time Polygon plan is required for truly live stock data.
POLYGON_API_KEY=

# The app blocks bars older than this many minutes so delayed/stale data does not masquerade as live.
LIVE_DATA_MAX_AGE_MINUTES=5

# Optional future providers. Do not expose provider keys with NEXT_PUBLIC_ prefixes.
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
COINGECKO_API_KEY=
YAHOO_FINANCE_API_KEY=
